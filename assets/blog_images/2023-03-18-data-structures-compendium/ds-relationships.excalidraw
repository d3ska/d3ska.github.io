      "boundElements": null,
      "updated": 1709300000000,
      "link": null,
      "locked": false,
      "text": "Arrays back Hash Tables internally. Stacks & Queues can be built on Arrays or Linked Lists.",
      "fontSize": 13,
      "fontFamily": 1,
