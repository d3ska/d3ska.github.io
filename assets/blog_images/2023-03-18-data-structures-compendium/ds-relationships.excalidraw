      "boundElements": null,
      "updated": 1709300000000,
      "link": null,
      "locked": false,
      "text": "Heaps and Tries specialize from Trees. Sets are backed by Hash Tables (HashSet) or Trees (TreeSet).",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Heaps and Tries specialize from Trees. Sets are backed by Hash Tables (HashSet) or Trees (TreeSet).",
